# Application
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:6543/postgres?pgbouncer=true
MIGRATION_DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_ALLOWED_IPS=

# Upstream redeem provider
UPSTREAM_BASE_URL=https://gpt.86gamestore.com
UPSTREAM_API_KEY=

# Card security
CARD_ENCRYPTION_KEY=replace-with-32-byte-encryption-key

# Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key
ALIPAY_NOTIFY_URL=https://your-domain.example.com/api/orders/pay/callback
